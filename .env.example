# Copier en .env à la racine (optionnel — docker-compose a des valeurs dev par défaut).
# Ne jamais committer le fichier .env.

# Secrets JWT (partagés gateway + auth-service + microservices)
JWT_SECRET=dev-jwt-secret-change-me
INTERNAL_SHARED_SECRET=dev-internal-secret

# Ports exposés sur l'hôte
GATEWAY_PORT=8082
WEB_PORT=5180

# Production — ajouter le domaine HTTPS du frontend (gateway CORS)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5180,https://bloomaroneschool.bloomarone.com
