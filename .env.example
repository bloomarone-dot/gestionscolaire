# Copier ce fichier en .env et adapter les valeurs.
# Ne jamais committer le fichier .env (mots de passe, clés secrètes).

# ── Production / client (obligatoire) ──
SECRET_KEY=remplacer-par-une-cle-longue-et-aleatoire
SEED_DEMO_ON_START=false

# ── Base de données (Docker) ──
DATABASE_URL=sqlite:////app/data/master.db
TENANT_DB_DIR=/app/data/tenants

# ── Fuseau horaire (délais de saisie des notes) ──
TZ=Africa/Douala

# ── JWT ──
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS (dev local uniquement si frontend séparé) ──
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Développement local avec comptes démo (ne pas activer en prod) ──
# SEED_DEMO_ON_START=true
