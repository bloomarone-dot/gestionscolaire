# Copier en .env à la racine (optionnel — docker-compose a des valeurs dev par défaut).
# Ne jamais committer le fichier .env.

# Secrets JWT (partagés gateway + auth-service + microservices)
JWT_SECRET=dev-jwt-secret-change-me
INTERNAL_SHARED_SECRET=dev-internal-secret

# Ports exposés sur l'hôte
GATEWAY_PORT=8082
WEB_PORT=5180

# Production — ajouter le domaine HTTPS du frontend (gateway CORS)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5180,https://bloomaroneschool.bloomarone.com

# Paiement parent — URL publique du site (liens /payer/… et webhook Orange)
# PUBLIC_APP_URL=https://bloomaroneschool.bloomarone.com

# Orange Money Local API (Y-Note / AREA GROUP PLUS) — NE JAMAIS committer les vraies valeurs
# MOBILE_PAYMENT_SANDBOX=false
# ORANGE_MONEY_API_URL=https://api-s1.orange.cm
# ORANGE_MONEY_USERNAME=
# ORANGE_MONEY_PASSWORD=
# ORANGE_MONEY_AUTH_TOKEN=
# ORANGE_MONEY_CHANNEL_MSISDN=640764857
# ORANGE_MONEY_PIN=
# ORANGE_MONEY_MERCHANT_USSD=#150*47*1017193#
# ORANGE_MONEY_NOTIF_URL=https://bloomaroneschool.bloomarone.com/tresorerie/webhooks/orange-money
