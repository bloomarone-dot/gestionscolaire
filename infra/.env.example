# Copier en .env dans ce dossier (infra/) et adapter pour le dev local.
# Ne jamais committer le vrai .env.

# Secret de signature des JWT — partagé entre auth-service et la gateway.
JWT_SECRET=dev-jwt-secret-change-me

# Secret du canal interne de confiance (en-têtes X-* entre gateway et services).
INTERNAL_SHARED_SECRET=dev-internal-secret
